# ============================================================================
# FoodFlux Application Configuration
# ============================================================================
# SECURITY WARNING: NEVER commit .env file with real credentials to git
# Create a local .env file in the project root and add your credentials there
# ============================================================================

# ============================================================================
# ADMIN AUTHENTICATION (CRITICAL - USE ENVIRONMENT VARIABLES)
# ============================================================================
# Admin login uses MOBILE NUMBER + PASSWORD for authentication
# These credentials are used to seed the admin account on application startup
# If the admin account does not exist in the database, it will be created automatically
#
# IMPORTANT:
# - ADMIN_MOBILE: 10-digit mobile number (digits only)
# - ADMIN_PASSWORD: Minimum 6 characters (will be hashed before storing)
# - NEVER hardcode these values in source code
# - NEVER expose these credentials in logs or frontend
# - ALWAYS use strong passwords in production

ADMIN_MOBILE=9999999999
ADMIN_PASSWORD=SecureAdminPassword@123

# ============================================================================
# MANAGER AUTHENTICATION
# ============================================================================
# Manager staff member authentication via mobile number + password

MANAGER_MOBILE=9000000001
MANAGER_EMAIL=manager@foodflux.local
MANAGER_PASSWORD=ManagerPassword@123

# ============================================================================
# APPLICATION SECURITY
# ============================================================================
# Flask secret key for session management and CSRF protection
# Use a strong, random value in production (generate with: python -c "import secrets; print(secrets.token_hex(32))")

SECRET_KEY=your-super-secret-key-change-in-production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Database file path (optional - defaults to ./database.db if not set)
# For Render deployments, use RENDER_DISK_MOUNT_PATH environment variable

DATABASE_PATH=

# ============================================================================
# RENDER DEPLOYMENT (optional)
# ============================================================================
# Set these when deploying on Render
# RENDER=true
# RENDER_DISK_MOUNT_PATH=/mnt/data

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Cache TTL in seconds (for order pricing, menu, etc.)

CACHE_TTL_SECONDS=15

# ============================================================================
# STATIC FILE CACHING
# ============================================================================
# Cache max age for static assets in seconds (default: 86400 = 24 hours)

STATIC_CACHE_SECONDS=86400

# ============================================================================
# SMS PROVIDER CONFIGURATION (optional)
# ============================================================================
# For production OTP/SMS services (if needed in future)
# OTP_SMS_PROVIDER=twilio|mock|other
# USE_REAL_SMS=false

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 1. For Render.com deployment:
#    - Create a .env file in the project root
#    - Set all required environment variables
#    - Use Render's environment variables dashboard to configure production secrets
#
# 2. For local development:
#    - Copy this file to .env
#    - Update ADMIN_MOBILE and ADMIN_PASSWORD with your desired values
#    - Never commit .env file to git
#
# 3. Security best practices:
#    - Use strong, unique passwords for admin and manager accounts
#    - Rotate admin credentials periodically
#    - Monitor admin login attempts and activity
#    - Keep Flask and dependencies updated
